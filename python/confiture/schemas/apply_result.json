{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApplyResult",
  "description": "Result of seed apply operation.",
  "type": "object",
  "required": [
    "total",
    "succeeded",
    "failed",
    "failed_files",
    "success"
  ],
  "properties": {
    "total": {
      "type": "integer"
    },
    "succeeded": {
      "type": "integer"
    },
    "failed": {
      "type": "integer"
    },
    "failed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}