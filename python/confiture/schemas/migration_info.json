{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MigrationInfo",
  "description": "Status of a single migration file.",
  "type": "object",
  "required": [
    "version",
    "name",
    "status",
    "applied_at"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "applied",
        "pending",
        "unknown"
      ]
    },
    "applied_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}