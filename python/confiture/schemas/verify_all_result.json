{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifyAllResult",
  "description": "Result of verifying all applied migrations.",
  "type": "object",
  "required": [
    "verified_count",
    "failed_count",
    "skipped_count",
    "total_applied",
    "results"
  ],
  "properties": {
    "verified_count": {
      "type": "integer"
    },
    "failed_count": {
      "type": "integer"
    },
    "skipped_count": {
      "type": "integer"
    },
    "total_applied": {
      "type": "integer"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "actual_value": {},
          "verify_file": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    }
  },
  "additionalProperties": false
}