{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DriftItem",
  "description": "A single schema drift item.",
  "type": "object",
  "required": [
    "type",
    "severity",
    "object",
    "message"
  ],
  "properties": {
    "type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "warning",
        "info"
      ]
    },
    "object": {
      "type": "string"
    },
    "expected": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "actual": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "message": {
      "type": "string"
    }
  },
  "additionalProperties": false
}