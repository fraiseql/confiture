{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifyResult",
  "description": "Result of verifying a single migration's post-conditions.",
  "type": "object",
  "required": [
    "version",
    "name",
    "status"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped",
        "error"
      ]
    },
    "actual_value": {},
    "verify_file": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}