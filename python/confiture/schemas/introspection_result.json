{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntrospectionResult",
  "description": "Top-level result of schema introspection.",
  "type": "object",
  "required": [
    "database",
    "schema",
    "introspected_at",
    "tables"
  ],
  "properties": {
    "database": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "introspected_at": {
      "type": "string",
      "format": "date-time"
    },
    "tables": {
      "type": "array",
      "items": {}
    }
  }
}